<!-- 16 Custom Wazuh Detection Rules - Mapped to MITRE ATT&CK Framework -->
<!--
  ══════════════════════════════════════════════════════════════
   Custom Wazuh Rules — Cloud Attack Range Detection
   Phase 3 — SSRF, IAM Escalation, Data Exfiltration
   Rule IDs: 100100–100199 (custom range)
   
   NOTE: These rules work with log_format=json, where Wazuh's
   built-in JSON decoder auto-parses all fields. No custom
   decoder is needed.
  ══════════════════════════════════════════════════════════════
-->

<group name="cloudtrail,attack_range,">

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  BASE RULE: Any CloudTrail event from our forwarder    -->
  <!--  Matches JSON-decoded events with "eventSource" field  -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <rule id="100100" level="3">
    <decoded_as>json</decoded_as>
    <field name="eventSource">securebank-api|dynamodb|s3|iam|sts</field>
    <description>CloudTrail: API event detected - $(eventName)</description>
    <group>cloudtrail_event,</group>
  </rule>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  SSRF DETECTION                                        -->
  <!-- ═══════════════════════════════════════════════════════ -->

  <!-- WARNING: Any SSRF attempt (catches all SSRFAttempt events) -->
  <rule id="100111" level="8">
    <if_sid>100100</if_sid>
    <field name="eventName">SSRFAttempt</field>
    <description>WARNING: SSRF attempt detected via verify-gateway endpoint. User: $(userIdentity.userName) from IP: $(sourceIPAddress)</description>
    <mitre>
      <id>T1190</id>
    </mitre>
    <group>ssrf,recon,</group>
  </rule>

  <!-- CRITICAL: SSRF targeting IMDS (escalates from 100111) -->
  <rule id="100110" level="15">
    <if_sid>100111</if_sid>
    <field name="requestParameters">imds|169\.254|meta-data|iam/security-credentials</field>
    <description>CRITICAL: SSRF attack targeting AWS IMDS detected! User: $(userIdentity.userName) from IP: $(sourceIPAddress)</description>
    <mitre>
      <id>T1190</id>
      <id>T1552.005</id>
    </mitre>
    <group>ssrf,credential_theft,attack_phase1,</group>
  </rule>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  AUTHENTICATION MONITORING                              -->
  <!-- ═══════════════════════════════════════════════════════ -->

  <!-- Login success -->
  <rule id="100120" level="3">
    <if_sid>100100</if_sid>
    <field name="eventName">ConsoleLogin</field>
    <field name="responseElements.ConsoleLogin">Success</field>
    <description>SecureBank: Successful login by $(userIdentity.userName) from $(sourceIPAddress)</description>
    <group>authentication,login_success,</group>
  </rule>

  <!-- Login failure -->
  <rule id="100121" level="6">
    <if_sid>100100</if_sid>
    <field name="eventName">ConsoleLoginFailure</field>
    <description>SecureBank: Failed login attempt for $(userIdentity.userName) from $(sourceIPAddress)</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>authentication,login_failure,</group>
  </rule>

  <!-- Brute force: 5 failed logins in 2 minutes -->
  <rule id="100122" level="12" frequency="5" timeframe="120">
    <if_matched_sid>100121</if_matched_sid>
    <same_source_ip />
    <description>ALERT: Brute force attack detected! 5+ failed logins from $(sourceIPAddress)</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>authentication,brute_force,</group>
  </rule>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  IAM PRIVILEGE ESCALATION                               -->
  <!-- ═══════════════════════════════════════════════════════ -->

  <rule id="100130" level="12">
    <if_sid>100100</if_sid>
    <field name="eventName">AssumeRole</field>
    <description>HIGH: IAM AssumeRole detected! User $(userIdentity.userName) from $(sourceIPAddress). Possible credential theft.</description>
    <mitre>
      <id>T1078</id>
      <id>T1548</id>
    </mitre>
    <group>iam,privilege_escalation,attack_phase2,</group>
  </rule>

  <rule id="100131" level="10">
    <if_sid>100100</if_sid>
    <field name="eventName">GetSessionToken</field>
    <description>WARNING: IAM session token generated by $(userIdentity.userName) from $(sourceIPAddress)</description>
    <mitre>
      <id>T1550.001</id>
    </mitre>
    <group>iam,token_generation,</group>
  </rule>

  <rule id="100132" level="12">
    <if_sid>100100</if_sid>
    <field name="eventName">CreateAccessKey</field>
    <description>HIGH: New IAM access key created by $(userIdentity.userName). Possible persistence mechanism!</description>
    <mitre>
      <id>T1098</id>
    </mitre>
    <group>iam,persistence,</group>
  </rule>

  <rule id="100133" level="14">
    <if_sid>100100</if_sid>
    <field name="eventName">AttachUserPolicy|PutUserPolicy|AttachRolePolicy</field>
    <description>CRITICAL: IAM policy modification by $(userIdentity.userName)! Privilege escalation attempt from $(sourceIPAddress)</description>
    <mitre>
      <id>T1098</id>
      <id>T1548</id>
    </mitre>
    <group>iam,privilege_escalation,</group>
  </rule>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  DATA EXFILTRATION — DynamoDB                           -->
  <!-- ═══════════════════════════════════════════════════════ -->

  <rule id="100140" level="14">
    <if_sid>100100</if_sid>
    <field name="eventName">Scan</field>
    <field name="eventSource">dynamodb</field>
    <description>CRITICAL: DynamoDB full table SCAN by $(userIdentity.userName) from $(sourceIPAddress). Data exfiltration in progress!</description>
    <mitre>
      <id>T1530</id>
      <id>T1005</id>
    </mitre>
    <group>dynamodb,data_exfiltration,attack_phase3,</group>
  </rule>

  <rule id="100141" level="8">
    <if_sid>100100</if_sid>
    <field name="eventName">GetItem</field>
    <field name="eventSource">dynamodb</field>
    <description>WARNING: DynamoDB GetItem by $(userIdentity.userName) from $(sourceIPAddress). Possible targeted data theft.</description>
    <mitre>
      <id>T1530</id>
    </mitre>
    <group>dynamodb,data_access,</group>
  </rule>

  <rule id="100142" level="14" frequency="10" timeframe="60">
    <if_matched_sid>100141</if_matched_sid>
    <same_source_ip />
    <description>CRITICAL: High-frequency DynamoDB access from $(sourceIPAddress)! Active data exfiltration.</description>
    <mitre>
      <id>T1530</id>
    </mitre>
    <group>dynamodb,data_exfiltration,</group>
  </rule>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  S3 BUCKET ACCESS                                       -->
  <!-- ═══════════════════════════════════════════════════════ -->

  <rule id="100150" level="6">
    <if_sid>100100</if_sid>
    <field name="eventName">GetObject</field>
    <field name="eventSource">s3</field>
    <description>S3 object accessed by $(userIdentity.userName) from $(sourceIPAddress)</description>
    <group>s3,data_access,</group>
  </rule>

  <rule id="100151" level="8">
    <if_sid>100100</if_sid>
    <field name="eventName">ListBuckets</field>
    <description>S3 bucket enumeration by $(userIdentity.userName) from $(sourceIPAddress). Reconnaissance activity.</description>
    <mitre>
      <id>T1580</id>
    </mitre>
    <group>s3,recon,</group>
  </rule>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  FUNDS TRANSFER MONITORING                              -->
  <!-- ═══════════════════════════════════════════════════════ -->

  <rule id="100160" level="5">
    <if_sid>100100</if_sid>
    <field name="eventName">FundsTransfer</field>
    <description>SecureBank: Funds transfer by $(userIdentity.userName)</description>
    <group>banking,transfer,</group>
  </rule>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!--  ATTACK CHAIN CORRELATION                               -->
  <!-- ═══════════════════════════════════════════════════════ -->

  <rule id="100170" level="15" frequency="2" timeframe="300">
    <if_matched_group>attack_phase1</if_matched_group>
    <same_source_ip />
    <description>ATTACK CHAIN: SSRF followed by credential theft detected from $(sourceIPAddress)! Full supply chain compromise in progress.</description>
    <mitre>
      <id>T1190</id>
      <id>T1552.005</id>
      <id>T1078</id>
    </mitre>
    <group>attack_chain,critical,</group>
  </rule>

</group>
